# GEMINI_API_KEY: Required for Gemini AI API calls when used.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: Public app URL.
APP_URL="http://localhost:3000"

# MongoDB connection string.
# Vercel: set either DATABASE_URL or MONGODB_URI in Project Settings > Environment Variables.
DATABASE_URL="<your-mongodb-atlas-uri>"
MONGODB_URI="mongodb://localhost:27017/vietkey-shop"

# JWT secret used to sign admin tokens.
JWT_SECRET="replace-with-a-long-random-secret"
