# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"

# MONGODB_URI: Required for MongoDB connection.
# Example: mongodb+srv://user:password@cluster.mongodb.net/vietkey-shop?retryWrites=true&w=majority
MONGODB_URI="mongodb://localhost:27017/vietkey-shop"

# JWT_SECRET: Secret key for JWT token signing (optional, defaults to hardcoded)
JWT_SECRET="vietkey_shop_secret_jwt_key_2026"
